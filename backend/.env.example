BIND_ADDR=0.0.0.0:8080
DATABASE_URL=sqlite://./happi.db?mode=rwc
# Required to validate Telegram WebApp initData (x-telegram-init-data).
TELEGRAM_BOT_TOKEN=
# Optional: in production set the webapp origin, e.g. https://your-webapp-host
# CORS_ALLOW_ORIGIN=

# Telegram webhook (optional)
# Public HTTPS webhook endpoint that Telegram should call, e.g.
# https://happiiiiibot.ammarfaisal.me/telegram/webhook
HOOK_URL=
# If set, `POST /telegram/webhook` requires:
#   X-Telegram-Bot-Api-Secret-Token: <WEBHOOK_SECRET_TOKEN>
WEBHOOK_SECRET_TOKEN=
# If set, the bot will reply to /start with a Web App button pointing here.
MINIAPP_URL=
